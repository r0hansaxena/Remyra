{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "declaration": true,
        "sourceMap": true
    },
    "include": [
        "./scripts",
        "./test",
        "./hardhat.config.ts"
    ],
    "exclude": [
        "node_modules",
        "artifacts",
        "cache",
        "frontend"
    ]
}